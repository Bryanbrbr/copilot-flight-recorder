# ─── Copilot Flight Recorder — Environment Variables ─────────────────────
# Copy to .env and fill in. Leave MSAL vars empty for dev mode (mock auth).

# ─── API Server ──────────────────────────────────────────────────────────
PORT=3001
# HOST=0.0.0.0
# DATABASE_PATH=./data/flight_recorder.db

# ─── Microsoft Entra ID (Azure AD) ──────────────────────────────────────
# Get from https://entra.microsoft.com → App registrations
# 1. Create app → set redirect URI to http://localhost:5173 (type: SPA)
# 2. API permissions: User.Read, SecurityEvents.Read.All, AuditLog.Read.All

# Backend JWT validation
MSAL_CLIENT_ID=
MSAL_TENANT_ID=common

# Frontend MSAL
VITE_MSAL_CLIENT_ID=
VITE_MSAL_TENANT_ID=common
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# ─── Frontend → Backend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── Production (set in Azure Container Apps) ───────────────────────────
# NODE_ENV=production
# PORT=8080
# DATABASE_PATH=/data/flight_recorder.db
